# =============================================================================
# Node.js / npm
# =============================================================================
# 依存パッケージ（npm installで再生成可能なので除外）
node_modules/
.npm/

# ロックファイル以外のnpmキャッシュ
.npmrc.local

# =============================================================================
# ビルド成果物
# =============================================================================
dist/
build/
out/
.next/
.nuxt/
.vite/

# =============================================================================
# 環境変数・機密情報（絶対にコミットしないこと）
# =============================================================================
.env
.env.*
!.env.example
*.local

# =============================================================================
# データベース
# =============================================================================
*.sqlite
*.sqlite3
*.db

# SQLite 履歴DB用データディレクトリ（Docker named volume で管理）
# ホスト環境ではバックエンド起動時に作成されるが、コミット対象外
backend/data/

# =============================================================================
# IDE / エディタ設定
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*.swn
.editorconfig.local

# =============================================================================
# OS固有ファイル
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# =============================================================================
# ログファイル
# =============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# テスト結果・カバレッジ
# =============================================================================
coverage/
test-results/
playwright-report/
playwright/.cache/
.nyc_output/

# =============================================================================
# TypeScriptキャッシュ
# =============================================================================
*.tsbuildinfo
tsconfig.tsbuildinfo

# =============================================================================
# キャッシュ・一時ファイル
# =============================================================================
.turbo/
.cache/
*.tmp
*.temp

# =============================================================================
# MCP設定（AIエージェント専用、共有不要）
# =============================================================================
.mcp.json
