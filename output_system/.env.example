# DataAgent 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定してください
# 注意: .env ファイルは絶対にコミットしないこと（.gitignoreで除外済み）

# =============================================================================
# Claude API 設定
# =============================================================================
# Anthropic Claude APIキー（自然言語→SQL変換に使用）
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# =============================================================================
# データベース接続設定
# =============================================================================
# データベース種類（postgresql または mysql）
DB_TYPE=postgresql

# データベースホスト名
DB_HOST=localhost

# データベースポート番号（PostgreSQL: 5432, MySQL: 3306）
DB_PORT=5432

# データベースユーザー名（読み取り専用ユーザーを推奨）
DB_USER=readonly_user

# データベースパスワード
DB_PASSWORD=your-db-password-here

# データベース名
DB_NAME=your_database_name

# =============================================================================
# ポート設定
# =============================================================================
# バックエンド（Express）のポート番号
BACKEND_PORT=3002

# フロントエンド（Vite）のポート番号
FRONTEND_PORT=3001

# =============================================================================
# セキュリティ設定
# =============================================================================
# CORS で許可するオリジン（カンマ区切りで複数指定可能）
# デフォルト: localhost:3001 および コンテナ名:3001
# Docker環境では以下のようにコンテナ名を含めること:
#   CORS_ALLOWED_ORIGINS=http://localhost:3001,http://okegawaatclink-gaido-dataagent-output-system:3001
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://okegawaatclink-gaido-dataagent-output-system:3001

# POST /api/chat レートリミット設定（Cost Amplification Attack 対策）
# CHAT_RATE_LIMIT_MAX: ウィンドウ期間内の最大リクエスト数（デフォルト: 10）
CHAT_RATE_LIMIT_MAX=10
# CHAT_RATE_LIMIT_WINDOW: ウィンドウ期間（秒）（デフォルト: 60）
CHAT_RATE_LIMIT_WINDOW=60

# GET/DELETE /api/history レートリミット設定
# HISTORY_RATE_LIMIT_MAX: ウィンドウ期間内の最大リクエスト数（デフォルト: 60）
HISTORY_RATE_LIMIT_MAX=60
# HISTORY_RATE_LIMIT_WINDOW: ウィンドウ期間（秒）（デフォルト: 60）
HISTORY_RATE_LIMIT_WINDOW=60

# =============================================================================
# フロントエンド API設定（Vite環境変数）
# =============================================================================
# バックエンドAPIのベースURL
# Docker環境では以下のようにコンテナ名でアクセスするURLを設定する:
#   VITE_API_BASE_URL=http://okegawaatclink-gaido-dataagent-output-system-backend:3002
# ローカル開発時は:
#   VITE_API_BASE_URL=http://localhost:3002
# 注意: VITE_ プレフィックスが必要（Viteのクライアントサイド公開ルール）
VITE_API_BASE_URL=http://localhost:3002
