# DataAgent 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定してください
# 注意: .env ファイルは絶対にコミットしないこと（.gitignoreで除外済み）

# =============================================================================
# Claude API 設定
# =============================================================================
# Anthropic Claude APIキー（自然言語→SQL変換に使用）
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# =============================================================================
# データベース接続設定
# =============================================================================
# データベース種類（postgresql または mysql）
DB_TYPE=postgresql

# データベースホスト名
DB_HOST=localhost

# データベースポート番号（PostgreSQL: 5432, MySQL: 3306）
DB_PORT=5432

# データベースユーザー名（読み取り専用ユーザーを推奨）
DB_USER=readonly_user

# データベースパスワード
DB_PASSWORD=your-db-password-here

# データベース名
DB_NAME=your_database_name

# =============================================================================
# ポート設定
# =============================================================================
# バックエンド（Express）のポート番号
BACKEND_PORT=3002

# フロントエンド（Vite）のポート番号
FRONTEND_PORT=3001
